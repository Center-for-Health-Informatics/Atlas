{
  "name": "@chi/atlas",
  "version": "0.2.0",
  "description": "is an open source software tool for researchers to conduct scientific analyses on standardized observational data converted to the OMOP Common Data Model V5",
  "main": "js/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.js",
    "prep": "npm i && npm run clean && npm run genversion",
    "clean": "rimraf ./js/assets/bundle && rimraf ./js/assets/fonts && rimraf ./js/assets/images",
    "build": "npm run prep && npm run build:dev",
    "build:dev": "vite build --config vite.config.js",
    "build:docker": "npm run clean && npm run genversion && npm run build:dev && npm prune --production",
    "genversion": "node build/genversion.js",
    "test": "node --import ./tests/register-hooks.js --test",
    "lint": "eslint \"js/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint --fix \"js/**/*.js\" \"tests/**/*.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Center-for-Health-Informatics/Atlas.git"
  },
  "author": "Chris Knoll",
  "contributors": [
    "Alexander Saltykov <a_salt@live.ru>",
    "Sigfried Gold",
    "Frank DeFalco",
    "Anthony Sena",
    "Pavel Grafkin",
    "Vitaly Koulakov",
    "Jungmi Han",
    "Mark Velez",
    "Anton Gackovka",
    "Rob Ireton <iretonrt@ucmail.uc.edu>"
  ],
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Center-for-Health-Informatics/Atlas/issues"
  },
  "homepage": "https://github.com/Center-for-Health-Informatics/Atlas#readme",
  "devDependencies": {
    "@vitejs/plugin-legacy": "^8.2.1",
    "eslint": "^9.39.3",
    "neostandard": "^0.13.0",
    "playwright": "^1.61.1",
    "rimraf": "^6.1.3",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "@ohdsi/ui-toolbox": "^1.1.0",
    "@ohdsi/visibilityjs": "^2.0.2",
    "ajv": "^8.20.0",
    "bootstrap": "^3.4.1",
    "bootstrap-select": "^1.13.18",
    "clipboard": "^2.0.11",
    "colorbrewer": "^1.5.3",
    "crossfilter2": "^1.5.4",
    "d3": "^7.9.0",
    "d3-scale-chromatic": "^3.1.0",
    "d3-tip": "^0.9.1",
    "datatables.net": "^1.13.2",
    "datatables.net-buttons": "^2.3.4",
    "datatables.net-select": "^1.6.0",
    "director": "^1.2.8",
    "eonasdan-bootstrap-datetimepicker": "^4.17.49",
    "facets": "^0.1.1",
    "html2canvas": "^1.4.1",
    "jquery": "^1.12.4",
    "jquery-ui": "^1.13.2",
    "jszip": "^3.10.1",
    "knockout": "^3.5.1",
    "knockout-sortable": "^1.2.2",
    "less": "^4.7.0",
    "lodash": "^4.17.21",
    "lscache": "^1.3.2",
    "lz-string": "^1.4.4",
    "moment": "^2.29.4",
    "numeral": "^2.0.6",
    "ouanalyse-datatables.net-buttons-html5": "^1.5.3",
    "papaparse": "^5.3.2",
    "prismjs": "^1.29.0",
    "svgsaver": "^0.9.0",
    "venn.js": "^0.2.20",
    "xss": "^1.0.14"
  },
  "allowScripts": {
    "core-js@3.49.0": true,
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true
  }
}
